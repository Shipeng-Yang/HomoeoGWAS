# =============================================================================
# HomoeoGWAS .gitignore
# =============================================================================
# Strict exclusion of large data + intermediate artifacts.
# data/ alone is ~950 GB (raw VCFs, references, BLAST DBs).
# results/ is ~19 GB (Phase 1-5 outputs; reproducible via Snakemake).
# benchmarks/ is ~590 MB (8 baseline tool source trees; clone per
# scripts/reproduce_baselines.sh).
# =============================================================================

# ---------------------------------------------------------------------------
# Internal / assistant tooling — never part of the public software package
# (kept on disk for local workflow; scrubbed from history at release).
# ---------------------------------------------------------------------------
CLAUDE.md
codex_isolated.sh
codex*.sh

# ---------------------------------------------------------------------------
# Data and large reproducible outputs
# ---------------------------------------------------------------------------
data/
benchmarks/

# All run outputs are reproducible from reproducibility/ — not tracked.
# (paper result fingerprints live under reproducibility/paper/results_phase4/.)
results/
reports/
figures/
tables/

# ---------------------------------------------------------------------------
# Snakemake metadata + DAG caches
# ---------------------------------------------------------------------------
.snakemake/
*.snakemake.log

# ---------------------------------------------------------------------------
# Tool / state caches not part of the package
# ---------------------------------------------------------------------------
.codex_state/
.codex_logs/
# ignore local Claude settings/state, but ship the agent skill
.claude/*
!.claude/skills/
!.claude/skills/**
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.cache/

# ---------------------------------------------------------------------------
# Run logs (large, per-host)
# ---------------------------------------------------------------------------
logs/
*.log
nohup.out

# ---------------------------------------------------------------------------
# Local conda/venv envs (should never be in repo)
# ---------------------------------------------------------------------------
envs/
.venv/
venv/

# ---------------------------------------------------------------------------
# Python build / install artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.eggs/
pip-wheel-metadata/

# ---------------------------------------------------------------------------
# Notebooks / editors
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
.idea/
.vscode/
*.swp
*~

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Genomics intermediates that should never be tracked
# ---------------------------------------------------------------------------
*.bgen
*.bgi
*.sample
*.pgen
*.pvar
*.psam
*.bed
*.bim
*.fam
*.vcf
*.vcf.gz
*.vcf.gz.tbi
*.vcf.gz.csi
*.bcf
*.bam
*.cram
*.cram.crai
*.sam
*.fa
*.fasta
*.fa.gz
*.fasta.gz
*.fai
*.gff
*.gff3
*.gff3.gz

# ---------------------------------------------------------------------------
# plink2/bcftools/regenie scratch
# ---------------------------------------------------------------------------
plink2.log
plink.log
*.regenie.log

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
/tmp/

# ---------------------------------------------------------------------------
# Unpublished manuscript drafts — kept on disk, not tracked until publication
# ---------------------------------------------------------------------------
reproducibility/paper/notes/10_*
reproducibility/paper/notes/11_*
reproducibility/paper/notes/12_*
reproducibility/paper/notes/13_*
reproducibility/paper/notes/14_*
reproducibility/paper/notes/review/
